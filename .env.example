# Server Configuration
PORT=3000
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# Database
DATABASE_URL="postgresql://user:password@localhost:5432/truthlens?schema=public"

# Independent Model APIs (all 4 hosted separately)
# OCR_MODEL_API_URL can be either base URL (http://127.0.0.1:8000)
# or full endpoint URL (http://127.0.0.1:8000/extract-text)
OCR_MODEL_API_URL=http://127.0.0.1:8000
OCR_MODEL_API_KEY=
OCR_MODEL_API_TIMEOUT_MS=30000

FACT_CHECK_MODEL_API_URL=https://fact-check-model.your-domain.com
FACT_CHECK_MODEL_API_KEY=
FACT_CHECK_MODEL_API_TIMEOUT_MS=30000

TRANSLATION_MODEL_API_URL=https://translation-model.your-domain.com
TRANSLATION_MODEL_API_KEY=
TRANSLATION_MODEL_API_TIMEOUT_MS=30000

SPEECH_MODEL_API_URL=https://speech-model.your-domain.com
SPEECH_MODEL_API_KEY=
SPEECH_MODEL_API_TIMEOUT_MS=60000

# Existing service used by RAG
OPENAI_API_KEY=
